# =============================================
# AI WhatsApp Support Bot - Environment Config
# =============================================

# Server
PORT=3000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────
# Local MongoDB
MONGO_URI=mongodb://localhost:27017/whatsapp-bot

# OR MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/whatsapp-bot?retryWrites=true&w=majority

# ── Grok AI (xAI) ────────────────────────────
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-2-latest
GROK_BASE_URL=https://api.x.ai/v1

# ── App Settings ─────────────────────────────
MAX_TOKENS=1024
ESCALATION_EMAIL=support@yourstore.com
LOG_LEVEL=info
